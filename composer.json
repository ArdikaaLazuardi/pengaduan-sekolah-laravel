{
    "name": "smk/pengaduan-sekolah",
    "type": "project",
    "description": "Aplikasi Pengaduan Sarana Sekolah berbasis Laravel 9, MySQL, dan Bootstrap 5.",
    "keywords": ["laravel", "bootstrap", "mysql", "pengaduan", "sekolah"],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "laravel/framework": "^9.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.20",
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"echo file_exists('.env') ? 'File exists' : 'File not found';\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "ignore": [
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-w7xr-vk7n-rstm"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
